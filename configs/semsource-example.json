{
  "namespace": "acme",
  "sources": [
    {
      "type": "git",
      "url": "github.com/acme/gcs",
      "branch": "main",
      "watch": true
    },
    {
      "type": "ast",
      "path": "./",
      "language": "go",
      "watch": true
    },
    {
      "type": "docs",
      "paths": ["README.md", "docs/"],
      "watch": true
    },
    {
      "type": "config",
      "paths": ["go.mod", "Dockerfile"],
      "watch": true
    },
    {
      "type": "url",
      "urls": ["https://docs.acme.io/gcs"],
      "poll_interval": "300s"
    }
  ]
}
