{
  "namespace": "acme",
  "sources": [
    {
      "type": "ast",
      "path": "/workspace",
      "languages": [
        "go",
        "typescript",
        "javascript",
        "java",
        "python",
        "svelte"
      ],
      "watch": false
    }
  ],
  "source_roots": [
    "/workspace"
  ],
  "graph": {
    "embedder_type": "http",
    "index_workers": 4,
    "coalesce_ms": 200,
    "enable_clustering": true,
    "clustering_llm": true
  },
  "model_registry": {
    "endpoints": {
      "semembed": {
        "provider": "openai",
        "url": "http://localhost:8081/v1",
        "model": "Snowflake/snowflake-arctic-embed-s",
        "query_prefix": "Represent this sentence for searching relevant passages: "
      },
      "seminstruct": {
        "provider": "openai",
        "url": "http://localhost:8083/v1",
        "model": "qwen3-0.6b",
        "max_tokens": 16384
      }
    },
    "capabilities": {
      "embedding": {
        "preferred": [
          "semembed"
        ]
      },
      "community_summary": {
        "preferred": [
          "seminstruct"
        ]
      },
      "query_classification": {
        "preferred": [
          "seminstruct"
        ]
      },
      "answer_synthesis": {
        "preferred": [
          "seminstruct"
        ]
      }
    }
  }
}
