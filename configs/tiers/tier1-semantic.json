{
  "namespace": "acme",
  "sources": [
    { "type": "ast", "path": "/workspace", "languages": ["go", "typescript", "javascript", "java", "python", "svelte"], "watch": false }
  ],
  "source_roots": ["/workspace"],
  "graph": {
    "embedder_type": "http",
    "index_workers": 4,
    "coalesce_ms": 200
  },
  "model_registry": {
    "endpoints": {
      "semembed": {
        "provider": "openai",
        "url": "http://localhost:8081/v1",
        "model": "Snowflake/snowflake-arctic-embed-s",
        "query_prefix": "Represent this sentence for searching relevant passages: "
      }
    },
    "capabilities": {
      "embedding": { "preferred": ["semembed"] }
    },
    "defaults": { "model": "semembed" }
  }
}
