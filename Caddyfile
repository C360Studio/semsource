# Caddyfile for C360 Stack
# Reverse proxy: Routes semsource query/status APIs, legacy graph WebSocket,
# semstreams-ui, and future backends.
#
# Port map (internal Docker network):
#   semsource:7890  — Legacy raw graph WebSocket output
#   semsource:8080  — ServiceManager HTTP API
#   semsource:8082  — GraphQL gateway
#   semsource:9091  — Prometheus metrics
#   ui:5173         — SemStreams UI (Vite dev)
#   backend:8080    — Reserved for semspec/semdragon backend
#
# All traffic enters via :3000 on the host.

{
	auto_https off
	admin off
}

:3000 {
	# SemSource legacy graph WebSocket — proxied so clients connect via Caddy
	handle /graph {
		reverse_proxy semsource:7890
	}

	# SemSource graph query and source-manifest APIs
	handle /graphql* {
		reverse_proxy semsource:8082
	}
	handle /source-manifest/* {
		reverse_proxy semsource:8080
	}
	# Fused code_context queries (ADR-0004)
	handle /code-context/* {
		reverse_proxy semsource:8080
	}
	handle /metrics {
		reverse_proxy semsource:9091
	}

	# Health endpoint — checks the proxy is alive
	handle /semsource/health {
		respond "OK" 200
	}

	# Reserved: backend API routes (semspec, semdragon)
	# Uncomment when backends are added:
	# handle /api/* {
	# 	reverse_proxy backend:8080
	# }
	# handle /flowbuilder/* {
	# 	reverse_proxy backend:8080
	# }
	# handle /components/* {
	# 	reverse_proxy backend:8080
	# }
	# handle /health {
	# 	reverse_proxy backend:8080
	# }

	# SemStreams UI handles everything else
	handle {
		reverse_proxy {$UI_HOST:ui:5173}
	}

	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	encode gzip

	log {
		output stdout
		format json
		level {$LOG_LEVEL:INFO}
	}
}
