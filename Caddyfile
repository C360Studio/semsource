# Caddyfile for C360 Stack
# Reverse proxy: explicit SemSource workbench and advertised API allowlist.
#
# Port map (internal Docker network):
#   semsource:7890  — Raw graph WebSocket output
#   semsource:8080  — ServiceManager HTTP API, including /graph-gateway/graphql
#   semsource:9091  — Prometheus metrics
#   ui:3000         — SemSource workbench production server
#
# All traffic enters via :3000 on the host.
{
	auto_https off
	admin off
}

:3000 {
	# Exact non-prefix routes.
	handle /graph {
		reverse_proxy semsource:7890
	}
	handle /graphql {
		rewrite * /graph-gateway{uri}
		reverse_proxy semsource:8080
	}
	handle /metrics {
		reverse_proxy semsource:9091
	}
	handle /health {
		rewrite * /source-manifest/health
		reverse_proxy semsource:8080
	}

	# Advertised SemSource API prefixes.
	handle /source-manifest/* {
		reverse_proxy semsource:8080
	}
	handle /code-context/* {
		reverse_proxy semsource:8080
	}
	handle /doc-context/* {
		reverse_proxy semsource:8080
	}
	handle /mcp-gateway/* {
		reverse_proxy semsource:8080
	}

	# Only the shell root and SvelteKit build assets reach the UI process.
	handle / {
		reverse_proxy ui:3000
	}
	handle /_app/* {
		reverse_proxy ui:3000
	}

	# Unknown and retired product paths must never masquerade as UI HTML.
	handle {
		header Content-Type "application/json"
		respond `{"error":"not_found"}` 404
	}

	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	encode gzip

	log {
		output stdout
		format json
		level {$LOG_LEVEL:INFO}
	}
}
